{% macro publication_item(publication) %}
{{ anchor(publication) }}
- **{{ publication.title | markdown_link(publication.url) }}**. {{ publication.authors | join(", ") }}. *{{ publication.venue }}*{% if publication.publication_date %}, {{ publication.publication_date }}{% endif %}.
