{% if site.overview is defined %}
<section class="cv-section cv-section-overview" data-summary-level="{{ summary.active_level }}">
  <h2>Portfolio Summary</h2>
  <div class="cv-overview-grid">
    <div class="cv-overview-copy">
      {% for paragraph in summary.active.paragraphs %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
    <aside class="cv-dashboard cv-overview-metrics" aria-label="Portfolio metrics">
      <div><strong>{{ site.metrics.publications }}</strong><span>Total publications</span></div>
      <div><strong>{{ site.metrics.software_projects }}</strong><span>Software projects</span></div>
      <div><strong>{{ site.metrics.research_projects }}</strong><span>Research projects</span></div>
      <div><strong>{{ site.overview.teaching.total_hours_label }}</strong><span>Teaching hours</span></div>
      <div><strong>{{ site.metrics.work_institutions }}</strong><span>Work institutions</span></div>
      <div><strong>{{ site.overview.software.package_downloads_label }}</strong><span>Package downloads</span></div>
      <div><strong>{{ site.overview.dissemination.known_social_views_label }}</strong><span>Known social views</span></div>
    </aside>
  </div>
</section>
{% endif %}
