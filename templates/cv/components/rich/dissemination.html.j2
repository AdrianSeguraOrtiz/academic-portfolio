{% import "components/rich/macros.html.j2" as cv %}

{% if "dissemination" in sections and render_options.get("include_dissemination", true) %}
<section class="cv-section cv-section-dissemination">
  <h2>{{ t("cv.sections.dissemination_media") }}</h2>
  {% if site.dissemination_hub is defined %}
  <div class="cv-dissemination-summary">
    <article class="cv-chart-card">
      <h3>{{ t("cv.sections.total_dissemination_items") }}</h3>
      <strong class="cv-big-number">{{ site.dissemination_hub.total }}</strong>
    </article>
    <article class="cv-chart-card">
      <h3>{{ t("cv.sections.items_by_type") }}</h3>
      <div class="cv-bar-list compact">
        {% for category in site.dissemination_hub.categories %}
        <div class="cv-bar-row">
          <div class="cv-bar-label"><span>{{ category.label }}</span><strong>{{ category.count }}</strong></div>
          <div class="cv-bar-track dissemination-{{ category.id }}"><span style="width: {{ category.share }}%"></span></div>
        </div>
        {% endfor %}
      </div>
    </article>
  </div>

  {% if site.dissemination_hub.publication_groups %}
  <h3>{{ t("cv.sections.by_research_output") }}</h3>
  <div class="cv-compact-grid">
    {% for group in site.dissemination_hub.publication_groups %}
    <article class="cv-entry cv-dissemination-output">
      <h4>{{ group.publication.title | html_link(group.publication.url) }}</h4>
      <div class="cv-metric-strip">
        {% for badge in group.badges %}
        <span><strong>{{ badge.count }}</strong>{{ badge.label }}</span>
        {% endfor %}
      </div>
    </article>
    {% endfor %}
  </div>
  {% endif %}

  <h3>{{ t("cv.sections.dissemination_items") }}</h3>
  <div class="cv-compact-grid">
    {% for item in site.dissemination_hub["items"] %}
    {% if item.id %}<span id="{{ item.id }}" class="cv-anchor"></span>{% endif %}
    <article class="cv-entry cv-dissemination-item dissemination-{{ item.category }}">
      <header class="cv-entry-header">
        <p class="cv-label">{{ item.type_label }}</p>
        {% if item.date_label %}<p class="cv-date">{{ item.date_label }}</p>{% endif %}
      </header>
      <h4>{{ item.display_title | html_link(item.url) }}</h4>
      {% if item.source %}<p><strong>{{ item.source }}</strong></p>{% endif %}
      {% if item.description %}<p>{{ item.description }}</p>{% endif %}
      {% for detail in item.detail_lines %}<p class="cv-reference">{{ detail }}</p>{% endfor %}
      {% if item.get("resolved", {}).get("publication_ids", []) %}<p class="cv-reference">{{ t("cv.references.publications") }}: {{ item.resolved.publication_ids | linked_names }}</p>{% endif %}
      {% if item.get("resolved", {}).get("software_package_ids", []) %}<p class="cv-reference">{{ t("cv.references.software_packages") }}: {{ item.resolved.software_package_ids | linked_names }}</p>{% endif %}
    </article>
    {% endfor %}
  </div>
  {% else %}
  {{ cv.metric_strip(aggregates.dissemination.summary.metrics) }}
  {% endif %}
</section>
{% endif %}
