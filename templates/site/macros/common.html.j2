{% macro org_links(record) -%}
  {%- for organization in record.get("resolved", {}).get("organization_ids", []) -%}
    {%- if organization.website -%}<a href="{{ organization.website }}">{{ organization.name }}</a>{%- else -%}{{ organization.name }}{%- endif -%}{% if not loop.last %}, {% endif %}
  {%- endfor -%}
{%- endmacro %}

{% macro date_span(record) -%}
  {%- if record.get("start_date") or record.get("end_date") -%}
    {{ record.get("start_date") | date_range(record.get("end_date")) }}
  {%- endif -%}
{%- endmacro %}

{% macro linked_records(records) -%}
  {%- for record in records -%}
    {%- set url = record.get("url") or record.get("website") or record.get("urls", {}).get("github") -%}
    {%- if url -%}<a href="{{ url }}">{{ record | record_name }}</a>{%- else -%}{{ record | record_name }}{%- endif -%}{% if not loop.last %}, {% endif %}
  {%- endfor -%}
{%- endmacro %}

{% macro section_heading(eyebrow, title, compact=false) %}
<div class="section-heading{% if compact %} compact{% endif %}">
  <p class="eyebrow">{{ eyebrow }}</p>
  <h2>{{ title }}</h2>
</div>
{% endmacro %}

{% macro carousel_control(class_name, direction, data_attribute, label) -%}
<button class="carousel-control {{ class_name }} {{ direction }}" type="button" {{ data_attribute }} aria-label="{{ label }}">{{ "‹" if direction == "previous" else "›" }}</button>
{%- endmacro %}

{% macro publication_card(publication) %}
<article class="record-card">
  <div class="record-topline">
    <span class="kind-dot {{ publication.publication_kind }}"></span>
    <span>{{ t("cv.kinds.journal_paper") if publication.publication_kind == "journal" else t("cv.kinds.conference_paper") }}</span>
    {% if publication.publication_date %}<time>{{ publication.publication_date }}</time>{% endif %}
  </div>
  <h3><a href="{{ publication.url }}">{{ publication.title }}</a></h3>
  <p>{{ publication.authors | join(", ") }}</p>
  <p><strong>{{ publication.venue }}</strong>{% if publication.publisher %} · {{ publication.publisher }}{% endif %}</p>
  <details class="publication-meta-details" data-publication-meta-details open>
    <summary>{{ t("site.labels.publications_and_details") }}</summary>
    <ul class="meta-list">
      {% if publication.doi %}<li>DOI: <a href="{{ publication.url }}">{{ publication.doi }}</a></li>{% endif %}
      {% if publication.get("resolved", {}).get("organization_ids", []) %}<li>{{ t("labels.organizations") }}: {{ org_links(publication) }}</li>{% endif %}
      {% if publication.get("resolved", {}).get("position_ids", []) %}<li>{{ t("labels.positions") }}: {{ linked_records(publication.resolved.position_ids) }}</li>{% endif %}
      {% if publication.get("resolved", {}).get("stay_ids", []) %}<li>{{ t("labels.research_stays") }}: {{ linked_records(publication.resolved.stay_ids) }}</li>{% endif %}
      {% if publication.get("resolved", {}).get("grant_ids", []) %}<li>{{ t("labels.grants") }}: {{ linked_records(publication.resolved.grant_ids) }}</li>{% endif %}
      {% if publication.get("resolved", {}).get("software_project_ids", []) %}
      <li>{{ t("labels.software") }}:
        {% for software in publication.resolved.software_project_ids %}
        <a href="{{ software.urls.github }}">{{ software.name }}</a>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </li>
      {% endif %}
    </ul>
  </details>
</article>
{% endmacro %}
