{% import "macros/common.html.j2" as common %}
<section class="content-section" id="teaching">
  {{ common.section_heading(t("nav.teaching"), t("cv.sections.classes_supervision")) }}
  <div class="teaching-layout">
    <div class="teaching-chart-grid" aria-label="{{ t("site.aria.teaching_workload_charts") }}">
      <article class="teaching-hours-card teaching-year-chart">
        <div class="chart-heading">
          <span>{{ t("cv.metrics.classroom_hours") }}</span>
          <h3>{{ t("cv.sections.classroom_hours_by_year") }}</h3>
        </div>
        <div class="teaching-chart-legend" aria-label="{{ t("site.aria.academic_year_chart_legend") }}">
          {% for organization in teaching_hours_chart.legend %}
          <span><i style="--org-color: {{ organization.color }}"></i>{{ organization.label }}</span>
          {% endfor %}
        </div>
        <div class="teaching-year-bars">
          {% for row in teaching_hours_chart.by_academic_year %}
          <div class="teaching-year-bar" style="--bar-size: {{ row.share }}%">
            <span>{{ row.hours_label }}</span>
            <div class="teaching-year-stack">
              {% for segment in row.segments %}
              <i
                style="--org-color: {{ segment.color }}; --segment-size: {{ segment.share }}%"
                title="{{ segment.label }} · {{ segment.hours_label }}"
              ></i>
              {% endfor %}
            </div>
            <strong>{{ row.label }}</strong>
          </div>
          {% endfor %}
        </div>
      </article>
      <article class="teaching-hours-card teaching-degree-chart">
        <div class="chart-heading">
          <span>{{ t("cv.metrics.classroom_hours") }}</span>
          <h3>{{ t("cv.sections.classroom_hours_by_degree") }}</h3>
        </div>
        <div class="teaching-chart-legend" aria-label="{{ t("site.aria.degree_chart_legend") }}">
          {% for organization in teaching_hours_chart.legend %}
          <span><i style="--org-color: {{ organization.color }}"></i>{{ organization.label }}</span>
          {% endfor %}
        </div>
        <div class="teaching-degree-bars">
          {% for row in teaching_hours_chart.by_degree %}
          <div class="teaching-degree-row" style="--bar-size: {{ row.share }}%">
            <div>
              <strong>{{ row.label }}</strong>
              <span>{{ row.hours_label }}</span>
            </div>
            <div class="teaching-degree-stack">
              {% for segment in row.segments %}
              <i
                style="--org-color: {{ segment.color }}; --segment-size: {{ segment.share }}%"
                title="{{ segment.label }} · {{ segment.hours_label }}"
              ></i>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </article>
    </div>
    <article class="teaching-timeline-card">
      <div class="teaching-timeline-legends">
        <div class="teaching-organization-legend" aria-label="{{ t("site.aria.teaching_organization_legend") }}">
          {% for organization in teaching_timeline.legend %}
          <span><i style="--org-color: {{ organization.color }}"></i>{{ organization.label }}</span>
          {% endfor %}
        </div>
        <div class="teaching-type-legend" aria-label="{{ t("site.aria.teaching_type_legend") }}">
          <span><i class="type-class"></i> {{ t("site.labels.class") }}</span>
          <span><i class="type-supervision"></i> {{ t("site.labels.supervision") }}</span>
        </div>
        <div class="timeline-zoom-controls" aria-label="{{ t("site.aria.teaching_timeline_zoom_controls") }}">
          <button type="button" data-teaching-zoom-out aria-label="{{ t("site.actions.zoom_out_teaching_timeline") }}" title="{{ t("site.actions.zoom_out") }}">-</button>
          <button type="button" data-teaching-zoom-reset aria-label="{{ t("site.actions.reset_teaching_timeline_zoom") }}" title="{{ t("site.actions.reset_zoom") }}">{{ t("site.actions.reset") }}</button>
          <button type="button" data-teaching-zoom-in aria-label="{{ t("site.actions.zoom_in_teaching_timeline") }}" title="{{ t("site.actions.zoom_in") }}">+</button>
        </div>
      </div>
      <div class="teaching-timeline-scroll">
        <div class="teaching-timeline-frame">
          <div class="teaching-timeline-stage" style="{{ teaching_timeline.axis_style }}">
            <div class="teaching-axis"></div>
            {% for tick in teaching_timeline.year_ticks %}
            <span class="teaching-year-tick" style="--tick-top: {{ tick.top }}px">{{ tick.year }}</span>
            {% endfor %}
            {% for event in teaching_timeline.events %}
            <span class="teaching-timeline-connector side-{{ event.side }}" style="{{ event.connector_style }}"></span>
            <article class="teaching-timeline-item type-{{ event.type }} side-{{ event.side }}" style="{{ event.style }}">
              <div class="teaching-event-kind">{{ event.type_label }}</div>
              <h3>{% if event.url %}<a href="{{ event.url }}">{{ event.title }}</a>{% else %}{{ event.title }}{% endif %}</h3>
              <p>{{ event.subtitle }}</p>
              {% for detail in event.detail_lines %}<p>{{ detail }}</p>{% endfor %}
              {% if event.repository_url %}<p><a href="{{ event.repository_url }}">{{ t("site.labels.repository") }}</a></p>{% endif %}
              <time>{{ event.date_label }}</time>
            </article>
            {% endfor %}
          </div>
        </div>
      </div>
    </article>
  </div>
</section>
