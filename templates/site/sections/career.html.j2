{% import "macros/common.html.j2" as common %}
<section class="content-section" id="career">
  {{ common.section_heading("Career", "Education, Experience, Stays, Honors, and Grants") }}
  <div class="career-timeline-card">
    <div class="career-timeline-toolbar" aria-label="Career timeline filters">
      {% for filter in career_timeline.filters %}
      <button type="button" class="career-filter active" data-career-filter="{{ filter.id }}" aria-pressed="true">{{ filter.label }}</button>
      {% endfor %}
      <button type="button" class="career-reset" data-career-reset>Reset zoom</button>
    </div>
    <div class="career-timeline-scroll">
      <div class="career-timeline" data-career-timeline role="img" aria-label="Career timeline visualization">
        <span class="map-loading">Loading career timeline</span>
      </div>
    </div>
    <div class="career-timeline-legend" aria-label="Career timeline legend">
      <span><i class="legend-education"></i> Education</span>
      <span><i class="legend-experience"></i> Experience</span>
      <span><i class="legend-stay-block"></i> Research stay</span>
      <span><i class="legend-certification"></i> Certification</span>
      <span><i class="legend-honor"></i> Honor</span>
      <span><i class="legend-grant"></i> Grant-linked block</span>
    </div>
    <script type="application/json" id="career-timeline-data">{{ career_timeline | tojson }}</script>
  </div>
  <div class="career-detail-tabs" aria-label="Career detail categories">
    <a href="#career-education"><span>{{ career.degrees | length }}</span> Education</a>
    <a href="#career-experience"><span>{{ career.experience | length }}</span> Experience</a>
    <a href="#career-stays"><span>{{ career.research_stays | length }}</span> Stays</a>
    <a href="#career-certifications"><span>{{ career.certifications | length }}</span> Certifications</a>
    <a href="#career-honors"><span>{{ career.honors | length }}</span> Honors</a>
    <a href="#career-grants"><span>{{ career.grants | length }}</span> Grants</a>
  </div>
  <div class="career-detail-sections">
    <section id="career-education" class="career-detail-section education">
      <div class="career-detail-heading">
        <p class="eyebrow">Education</p>
        <h3>Degrees</h3>
      </div>
      <div class="career-card-grid">
      {% for degree in career.degrees %}
      <article class="career-card education">
        <div class="record-topline"><span>{{ degree.level }}</span><time>{{ degree.start_date | date_range(degree.end_date) }}</time></div>
        <h3>{{ degree.title }}</h3>
        <p>{{ common.org_links(degree) }} · {{ degree.start_date | date_range(degree.end_date) }}</p>
        {% if degree.grade %}<p>{{ degree.grade }}</p>{% endif %}
        {% if degree.get("resolved", {}).get("grant_ids", []) %}<p>Grants: {{ common.linked_records(degree.resolved.grant_ids) }}</p>{% endif %}
        {% if degree.thesis.title %}<p>{{ degree.thesis.type }}: {{ degree.thesis.title }}</p>{% endif %}
        {% if degree.thesis.area %}<p class="tags">{{ degree.thesis.area }}</p>{% endif %}
      </article>
      {% endfor %}
      </div>
    </section>
    <section id="career-experience" class="career-detail-section experience">
      <div class="career-detail-heading">
        <p class="eyebrow">Experience</p>
        <h3>Positions</h3>
      </div>
      <div class="career-card-grid experience-grid">
      {% for position in career.experience %}
      <article class="career-card experience">
        <div class="record-topline"><span>{{ position.employment_type or position.dedication or "Position" }}</span><time>{{ common.date_span(position) }}</time></div>
        <h3>{{ position.title }}</h3>
        <p>{{ common.org_links(position) }} · {{ common.date_span(position) }}</p>
        <ul class="meta-list">
          {% if position.location %}<li>Location: {{ position.location }}</li>{% endif %}
          {% if position.employment_type or position.dedication or position.work_mode %}<li>Type: {{ [position.employment_type, position.dedication, position.work_mode] | select | unique | join(", ") }}</li>{% endif %}
          {% if position.department %}<li>Department: {{ position.department }}</li>{% endif %}
          {% if position.group %}<li>Group: {{ position.group }}</li>{% endif %}
        </ul>
        {% if position.tasks %}
        <details class="task-details">
          <summary>Tasks ({{ position.tasks | length }})</summary>
          <ul class="meta-list">
            {% for task in position.tasks %}
            <li>{{ task }}</li>
            {% endfor %}
          </ul>
        </details>
        {% endif %}
      </article>
      {% endfor %}
      </div>
    </section>
    <section id="career-stays" class="career-detail-section stay">
      <div class="career-detail-heading">
        <p class="eyebrow">Research Stays</p>
        <h3>International Mobility</h3>
      </div>
      <div class="career-card-grid">
      {% for stay in career.research_stays %}
      <article class="career-card stay">
        <div class="record-topline"><span>{{ stay.type or "Research stay" }}</span><time>{{ common.date_span(stay) }}</time></div>
        <h3>{{ stay.title }}</h3>
        <p>{{ common.org_links(stay) }} · {{ common.date_span(stay) }}</p>
        <p>{{ stay.description }}</p>
        <ul class="meta-list">
          {% if stay.location.city %}<li>Location: {{ stay.location.city }}, {{ stay.location.country }}</li>{% endif %}
          {% if stay.host_group %}<li>Host group: {{ stay.host_group }}</li>{% endif %}
          {% if stay.purpose or stay.type %}<li>Purpose: {{ [stay.purpose, stay.type] | select | join(", ") }}</li>{% endif %}
          {% if stay.get("resolved", {}).get("grant_ids", []) %}<li>Grants: {{ common.linked_records(stay.resolved.grant_ids) }}</li>{% endif %}
          {% for task in stay.tasks %}<li>{{ task }}</li>{% endfor %}
        </ul>
      </article>
      {% endfor %}
      </div>
    </section>
    <section id="career-certifications" class="career-detail-section certification">
      <div class="career-detail-heading">
        <p class="eyebrow">Certifications</p>
        <h3>Credentials</h3>
      </div>
      <div class="career-card-grid compact-career-grid">
      {% for certification in career.certifications %}
      <article class="career-card certification">
        <div class="record-topline"><span>Certification</span>{% if certification.issue_date %}<time>{{ certification.issue_date }}</time>{% endif %}</div>
        <h3>{{ certification.title }}</h3>
        <p>{{ common.org_links(certification) }}{% if certification.issue_date %} · {{ certification.issue_date }}{% endif %}</p>
        <ul class="meta-list">
          {% if certification.duration_hours %}<li>{{ certification.duration_hours }} hours</li>{% endif %}
          {% if certification.credential_id %}<li>Credential ID: {{ certification.credential_id }}</li>{% endif %}
          {% if certification.notes %}<li>{{ certification.notes }}</li>{% endif %}
        </ul>
      </article>
      {% endfor %}
      </div>
    </section>
    <section id="career-honors" class="career-detail-section honor">
      <div class="career-detail-heading">
        <p class="eyebrow">Honors</p>
        <h3>Awards</h3>
      </div>
      <div class="career-card-grid compact-career-grid">
      {% for honor in career.honors %}
      <article class="career-card honor">
        <div class="record-topline"><span>Honor</span><time>{{ honor.issue_date }}</time></div>
        <h3>{{ honor.title }}</h3>
        <p>{{ honor.issue_date }} · {{ honor.awarding_entities | join(", ") }}</p>
        <p>{{ honor.context }}</p>
      </article>
      {% endfor %}
      </div>
    </section>
    <section id="career-grants" class="career-detail-section grant">
      <div class="career-detail-heading">
        <p class="eyebrow">Grants</p>
        <h3>Funding</h3>
      </div>
      <div class="career-card-grid compact-career-grid">
      {% for grant in career.grants %}
      <article class="career-card grant">
        <div class="record-topline"><span>{{ grant.awarding_entity_type }}</span><time>{{ grant.issue_date }}</time></div>
        <h3>{{ grant.name }}</h3>
        <p>{{ grant.issue_date }} · {{ grant.awarding_entity }}</p>
        <p>{{ grant.purpose }}</p>
        {% if common.date_span(grant) %}<p class="tags">{{ common.date_span(grant) }}</p>{% endif %}
        {% if grant.notes %}<p>{{ grant.notes }}</p>{% endif %}
      </article>
      {% endfor %}
      </div>
    </section>
  </div>
</section>
