{% import "macros/common.html.j2" as common %}
<section class="section overview" id="overview">
  <div class="overview-copy">
    {{ common.section_heading(t("nav.overview"), t("cv.sections.portfolio_summary")) }}

    <div class="narrative">
      <p>
        {{ t("site.overview.intro") }}
      </p>
      <p>
        {{ t("site.overview.academic_background", degrees=overview.education.degrees_html) | safe }}
        {{ t("site.overview.professional_and_stays",
          experience=overview.experience.by_institution_html,
          stays=overview.internationalization.stays_html,
          months="<strong>" ~ unit("month", overview.internationalization.total_stay_months) ~ "</strong>"
        ) | safe }}
        {{ t("site.overview.direct_work",
          institutions="<strong>" ~ unit("institution", metrics.work_institutions) ~ "</strong>"
        ) | safe }}
      </p>
      <p>
        {{ t("site.overview.research_output",
          journal="<strong>" ~ overview.research.journal_papers_phrase ~ "</strong>",
          conference="<strong>" ~ overview.research.conference_papers_phrase ~ "</strong>",
          international="<strong>" ~ overview.internationalization.international_publications_phrase ~ "</strong>",
          national="<strong>" ~ overview.internationalization.national_multicity_publications_phrase ~ "</strong>"
        ) | safe }}
        {{ t("site.overview.research_roles_reviews",
          roles="<strong>" ~ overview.research.project_roles_text ~ "</strong>",
          manuscripts="<strong>" ~ unit("manuscript", metrics.reviewed_manuscripts) ~ "</strong>"
        ) | safe }}
      </p>
      <p>
        {{ t("site.overview.software_counts",
          projects="<strong>" ~ plural("cv.counts.software_project", metrics.software_projects) ~ "</strong>",
          packages="<strong>" ~ plural("cv.counts.published_package", metrics.software_packages) ~ "</strong>"
        ) | safe }}
        {% if overview.software.repositories_with_stats %}
        {{ t("site.overview.software_public_activity",
          repositories="<strong>" ~ unit("repository", overview.software.repositories_with_stats) ~ "</strong>",
          stars="<strong>" ~ unit("star", overview.software.total_stars) ~ "</strong>",
          forks="<strong>" ~ unit("fork", overview.software.total_forks) ~ "</strong>"
        ) | safe }}
        {% endif %}
        {% if metrics.package_downloads %}
        {{ t("site.overview.package_usage",
          downloads="<strong>" ~ unit("download", metrics.package_downloads, display_count=overview.software.package_downloads_label) ~ "</strong>"
        ) | safe }}
        {% endif %}
      </p>
      <p>
        {{ t("site.overview.teaching_activity",
          institutions="<strong>" ~ overview.teaching.institution_years_text ~ "</strong>",
          hours="<strong>" ~ unit("hour", overview.teaching.total_hours, display_count=overview.teaching.total_hours_label) ~ "</strong>",
          years="<strong>" ~ plural("cv.counts.academic_year", overview.teaching.academic_years) ~ "</strong>",
          courses="<strong>" ~ unit("course", overview.teaching.courses) ~ "</strong>",
          degree_programmes="<strong>" ~ unit("degree_program", overview.teaching.degree_programs) ~ "</strong>"
        ) | safe }}
        {% if overview.teaching.first_academic_year and overview.teaching.first_institution %}
        {{ t("site.overview.teaching_recommendation",
          first_year=overview.teaching.first_academic_year,
          institution=overview.teaching.first_institution | e
        ) | safe }}
        {% endif %}
        {% if overview.teaching.teaching_innovation_projects %}
        {{ t("site.overview.teaching_innovation",
          projects="<strong>" ~ overview.teaching.teaching_innovation_projects_phrase ~ "</strong>"
        ) | safe }}
        {% endif %}
        {% if overview.teaching.supervision_text %}
        {{ t("site.overview.academic_supervision",
          supervision="<strong>" ~ overview.teaching.supervision_text ~ "</strong>"
        ) | safe }}
        {% endif %}
      </p>
      <p>
        {{ t("site.overview.dissemination_activity",
          items="<strong>" ~ overview.dissemination.activity_text ~ "</strong>"
        ) | safe }}
        {% if overview.dissemination.press_outlets %}
        {{ t("site.overview.press_coverage",
          outlets="<strong>" ~ unit("outlet", overview.dissemination.press_outlets) ~ "</strong>"
        ) | safe }}
        {% endif %}
        {% if metrics.known_social_views %}
        {{ t("site.overview.social_views",
          views="<strong>" ~ unit("view", metrics.known_social_views, display_count=overview.dissemination.known_social_views_label) ~ "</strong>",
          highest="<strong>" ~ unit("view", overview.dissemination.highest_social_views, display_count=overview.dissemination.highest_social_views_label) ~ "</strong>"
        ) | safe }}
        {% endif %}
      </p>
      <p>
        {{ t("site.overview.recognition",
          honors="<strong>" ~ overview.recognition.honors_phrase ~ "</strong>",
          honors_list=overview.recognition.honors_html,
          grants="<strong>" ~ overview.recognition.grants_phrase ~ "</strong>",
          grants_list=overview.recognition.grants_html
        ) | safe }}
      </p>
    </div>
  </div>

  <aside class="metric-grid" aria-label="{{ t("site.aria.portfolio_metrics") }}">
    <article class="metric-card"><strong>{{ metrics.publications }}</strong><span>{{ t("cv.metrics.total_publications") }}</span></article>
    <article class="metric-card"><strong>{{ metrics.software_projects }}</strong><span>{{ t("cv.metrics.software_projects") }}</span></article>
    <article class="metric-card"><strong>{{ metrics.research_projects }}</strong><span>{{ t("cv.metrics.research_projects") }}</span></article>
    <article class="metric-card"><strong>{{ overview.teaching.total_hours_label }}</strong><span>{{ t("cv.metrics.teaching_hours") }}</span></article>
    <article class="metric-card"><strong>{{ metrics.work_institutions }}</strong><span>{{ t("cv.metrics.work_institutions") }}</span></article>
    <article class="metric-card"><strong>{{ overview.software.package_downloads_label }}</strong><span>{{ t("cv.metrics.package_downloads") }}</span></article>
    <article class="metric-card"><strong>{{ overview.dissemination.known_social_views_label }}</strong><span>{{ t("cv.metrics.known_social_views") }}</span></article>
  </aside>
</section>
