{% import "macros/common.html.j2" as common %}
<section class="content-section" id="software">
  {{ common.section_heading(t("site.labels.open_research_software"), t("cv.sections.software")) }}
  <h3 class="subsection-title">{{ t("cv.sections.software_projects") }}</h3>
  {% if software_timeline.rows %}
  <div class="software-visual-grid">
    <article class="chart-card software-timeline-card">
      {{ common.section_heading(t("site.labels.repositories"), t("cv.sections.commit_activity"), compact=true) }}
      <div class="software-timeline-scroll">
        <div class="timeline-years" style="grid-template-columns: repeat({{ software_timeline.years | length }}, minmax(0, 1fr))">
          {% for year in software_timeline.years %}
          <span>{{ year }}</span>
          {% endfor %}
        </div>
        <div class="timeline-rows">
          {% for item in software_timeline.rows %}
          {% set github = item.project.get("github") %}
          <div class="timeline-row" style="--language-color: {{ item.color }};">
            <a class="timeline-label timeline-label-start" href="{{ item.project.urls.github }}">{{ item.project.name }}</a>
            <div class="timeline-track">
              {% for month in item.months %}
              <span class="activity-pulse" style="--left: {{ month.left }}%; --width: {{ month.width }}%; --height: {{ month.height }}px;" title="{{ unit("commit", month.count) }} · {{ month.month }}"></span>
              {% endfor %}
              {% if item.created_left is not none %}<span class="timeline-marker created" style="--left: {{ item.created_left }}%;" title="{{ t("site.labels.repository_created", date=github.created_at[:10]) }}"></span>{% endif %}
              {% if item.pushed_left is not none %}<span class="timeline-marker pushed" style="--left: {{ item.pushed_left }}%;" title="{{ t("cv.metrics.latest_push") }}: {{ github.pushed_at[:10] }}"></span>{% endif %}
            </div>
            <a class="timeline-label timeline-label-end" href="{{ item.project.urls.github }}" aria-hidden="true" tabindex="-1">{{ item.project.name }}</a>
          </div>
          {% endfor %}
        </div>
      </div>
    </article>

    {% if software_language_chart %}
    <article class="chart-card language-card">
      {{ common.section_heading(t("site.labels.codebase"), t("cv.sections.languages"), compact=true) }}
      <div class="language-stack" aria-label="{{ t("site.aria.aggregated_repository_languages") }}">
        {% for language in software_language_chart %}
        <span style="width: {{ language.share }}%; background: {{ language.color }};" title="{{ language.name }}: {{ language.share }}%"></span>
        {% endfor %}
      </div>
      <div class="language-list">
        {% for language in software_language_chart %}
        <div>
          <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
          <strong>{{ language.share }}%</strong>
        </div>
        {% endfor %}
      </div>
    </article>
    {% endif %}
  </div>
  {% endif %}
  <div class="software-layout">
    <aside class="software-snapshot" aria-label="{{ t("site.aria.software_portfolio_metrics") }}">
      <div class="section-heading compact">
        <p class="eyebrow">{{ t("site.labels.snapshot") }}</p>
        <h3>{{ t("site.labels.software_index") }}</h3>
      </div>
      <div class="snapshot-grid">
        <div><strong>{{ metrics.software_projects }}</strong><span>{{ t("site.labels.repos") }}</span></div>
        <div><strong>{{ metrics.software_packages }}</strong><span>{{ t("site.labels.packages") }}</span></div>
        {% if software_github.repositories_with_stats %}
        <div><strong>{{ software_github.total_stars }}</strong><span>{{ t("cv.metrics.stars") }}</span></div>
        <div><strong>{{ software_github.total_forks }}</strong><span>{{ t("cv.metrics.forks") }}</span></div>
        {% endif %}
      </div>
      {% if software_github.repositories_with_stats %}
      <div class="snapshot-detail">
        <span>{{ t("cv.metrics.latest_push") }}</span>
        <strong>{{ software_github.last_push_date }}</strong>
      </div>
      {% endif %}
      {% if software_language_chart %}
      <div class="snapshot-detail">
        <span>{{ t("site.labels.dominant_language") }}</span>
        <strong>{{ software_language_chart[0].name }}</strong>
      </div>
      <div class="snapshot-language-key">
        {% for language in software_language_chart %}
        <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </aside>
    <div class="software-carousel repo-carousel-shell" data-software-carousel data-repo-carousel>
      {{ common.carousel_control("software-carousel-control", "previous", "data-software-carousel-prev", t("site.actions.previous_repository")) }}
      <div class="repo-list" data-software-carousel-track>
        {% for project in software_projects %}
        {% set github = project.get("github") %}
        <article class="repo-row" data-software-carousel-item>
          <div class="repo-identity">
            <div class="software-meta">
              <span>{{ project.type }}</span>
            </div>
            <h3>{% if project.urls.github %}<a href="{{ project.urls.github }}">{{ project.name }}</a>{% else %}{{ project.name }}{% endif %}</h3>
            {% if project.full_name %}<p>{{ project.full_name }}</p>{% endif %}
          </div>
          <div class="repo-summary">
            {% if project.description %}<p>{{ project.description }}</p>{% endif %}
            <div class="repo-tags">
              {% for domain in project.domains %}
              <span>{{ domain }}</span>
              {% endfor %}
            </div>
          </div>
          {% if github %}
          <div class="repo-stats">
            <div class="repo-statline">
              {% if github.language %}<span>{{ github.language }}</span>{% endif %}
              {% if github.license %}<span>{{ github.license }}</span>{% endif %}
              <span>{{ unit("star", github.stargazers_count) }}</span>
              <span>{{ unit("fork", github.forks_count) }}</span>
              <span>{{ unit("open_issue", github.open_issues_count) }}</span>
              {% if github.commits_count is not none %}<span>{{ unit("commit", github.commits_count) }}</span>{% endif %}
            </div>
            {% if github.first_commit_at or github.last_commit_at or github.pushed_at %}
            <div class="repo-dates">
              {% if github.first_commit_at and github.last_commit_at %}
              <span>{{ t("site.labels.commits_date_range", start=github.first_commit_at[:10], end=github.last_commit_at[:10]) }}</span>
              {% endif %}
              {% if github.pushed_at %}
              <span>{{ t("cv.labels.push") }} {{ github.pushed_at[:10] }}</span>
              {% endif %}
            </div>
            {% endif %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </div>
      {{ common.carousel_control("software-carousel-control", "next", "data-software-carousel-next", t("site.actions.next_repository")) }}
    </div>
  </div>
  <h3 class="subsection-title">{{ t("cv.sections.software_packages") }}</h3>
  <div class="software-carousel package-carousel-shell" data-software-carousel data-package-carousel>
    {{ common.carousel_control("software-carousel-control", "previous", "data-software-carousel-prev", t("site.actions.previous_software_package")) }}
    <div class="package-grid" data-software-carousel-track>
    {% for package in software_packages %}
    {% set stats = package.get("package_stats", {}) %}
    <article class="package-card" data-software-carousel-item>
      <div class="software-meta"><span>{{ package.ecosystem }}</span>{% if package.get("package_name") %}<span>{{ package.package_name }}</span>{% endif %}{% if package.get("group_id") %}<span>{{ package.group_id }}:{{ package.artifact_id }}</span>{% endif %}</div>
      <h3><a href="{{ stats.get("package_url") or stats.get("mvnrepository_url") or package.get("url", "#") }}">{{ package.name }}</a></h3>
      {% if stats.get("summary") %}<p>{{ stats.summary }}</p>{% endif %}

      {% if package.ecosystem == "PyPI" and stats %}
      <div class="package-stat-grid">
        <div><strong>{{ stats.total_downloads | number }}</strong><span>{{ t("cv.fields.total_downloads") }}</span></div>
        <div><strong>{{ stats.latest_version }}</strong><span>{{ t("cv.fields.latest_version") }}</span></div>
        <div><strong>{{ stats.release_count }}</strong><span>{{ t("cv.fields.releases") }}</span></div>
        <div><strong>{{ stats.requires_python or "n/a" }}</strong><span>{{ t("site.labels.python") }}</span></div>
      </div>
      {% if stats.download_chart %}
      {% set chart_points = stats.download_chart[-18:] %}
      {% set max_downloads = chart_points | map(attribute="downloads") | max %}
      <div class="package-download-chart" aria-label="{{ t("site.labels.version_downloads_chart", package=package.name) }}">
        <div class="chart-y-axis">
          <span>{{ max_downloads | number }}</span>
          <span>{{ (max_downloads / 2) | round | int | number }}</span>
          <span>0</span>
        </div>
        <div class="chart-plot">
          <div class="chart-grid-line top"></div>
          <div class="chart-grid-line middle"></div>
          <div class="package-bars">
            {% for point in chart_points %}
            <div class="package-bar" style="height: {{ ((point.downloads / max_downloads) * 100) | round }}%" title="{{ point.label }} · {{ unit("download", point.downloads, display_count=(point.downloads | number)) }}">
              {% for segment in point.segments %}
              <span style="height: {{ segment.share }}%; background: {{ segment.color }};" title="{{ point.label }} · {{ segment.version }} · {{ unit("download", segment.downloads, display_count=(segment.downloads | number)) }}"></span>
              {% endfor %}
            </div>
            {% endfor %}
          </div>
          <div class="chart-x-axis">
            {% for point in chart_points %}
            <span>{{ point.label.split(" ")[0] }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
      {% endif %}
      <div class="package-splits">
        <div>
          <h4>{{ t("site.labels.versions") }}</h4>
          <div class="package-scroll-list">
            {% for item in stats.downloads_by_version %}
            <p><span><i style="background: {{ item.color }};"></i>{{ item.version }}</span><strong>{{ item.downloads | number }}</strong></p>
            {% endfor %}
          </div>
        </div>
        <div>
          <h4>{{ t("site.labels.countries") }}</h4>
          <div class="package-scroll-list">
            {% for item in stats.downloads_by_country %}
            <p><span>{{ item.country_code }}</span><strong>{{ item.downloads | number }}</strong></p>
            {% endfor %}
          </div>
        </div>
      </div>
      <p class="tags"><a href="{{ stats.clickpy_url }}">{{ t("site.labels.clickpy_dashboard") }}</a></p>
      {% elif package.ecosystem == "Maven" and stats %}
      <div class="package-stat-grid">
        <div><strong>{{ stats.latest_version }}</strong><span>{{ t("cv.fields.latest_version") }}</span></div>
        <div><strong>{{ stats.release_count }}</strong><span>{{ t("cv.fields.releases") }}</span></div>
        <div><strong>{{ stats.dependency_count }}</strong><span>{{ t("cv.fields.dependencies") }}</span></div>
        <div><strong>{{ stats.java_release or "n/a" }}</strong><span>{{ t("cv.fields.java_release") }}</span></div>
      </div>
      <ul class="meta-list">
        {% if stats.license %}<li>{{ t("cv.fields.license") }}: {{ stats.license }}</li>{% endif %}
        {% if stats.last_updated %}<li>{{ t("cv.fields.last_updated") }}: {{ stats.last_updated }}</li>{% endif %}
        {% if stats.project_url %}<li>{{ t("site.labels.project") }}: <a href="{{ stats.project_url }}">{{ stats.project_url }}</a></li>{% endif %}
      </ul>
      {% if stats.artifact_files %}
      <div class="artifact-list">
        {% for artifact in stats.artifact_files %}
        <a href="{{ artifact.url }}"><span>{{ artifact.kind }}</span><strong>{{ (artifact.size_bytes / 1024) | round | int }} KB</strong></a>
        {% endfor %}
      </div>
      {% endif %}
      <p class="tags"><a href="{{ stats.mvnrepository_url }}">MvnRepository</a></p>
      {% else %}
      <p class="tags">
        {% if package.get("package_name") %}{{ t("site.labels.package") }}: {{ package.package_name }}{% endif %}
        {% if package.get("group_id") %}{{ t("cv.labels.coordinate") }}: {{ package.group_id }}:{{ package.artifact_id }}{% endif %}
      </p>
      {% endif %}
    </article>
    {% endfor %}
    </div>
    {{ common.carousel_control("software-carousel-control", "next", "data-software-carousel-next", t("site.actions.next_software_package")) }}
  </div>
</section>
