{% import "macros/common.html.j2" as common %}
<section class="content-section" id="software">
  {{ common.section_heading("Open Research Software", "Software") }}
  <h3 class="subsection-title">Software Projects</h3>
  {% if software_timeline.rows %}
  <div class="software-visual-grid">
    <article class="chart-card software-timeline-card">
      {{ common.section_heading("Repositories", "Commit Activity", compact=true) }}
      <div class="timeline-years" style="grid-template-columns: repeat({{ software_timeline.years | length }}, minmax(0, 1fr))">
        {% for year in software_timeline.years %}
        <span>{{ year }}</span>
        {% endfor %}
      </div>
      <div class="timeline-rows">
        {% for item in software_timeline.rows %}
        {% set github = item.project.get("github") %}
        <div class="timeline-row" style="--language-color: {{ item.color }};">
          <a class="timeline-label" href="{{ item.project.urls.github }}">{{ item.project.name }}</a>
          <div class="timeline-track">
            {% for month in item.months %}
            <span class="activity-pulse" style="--left: {{ month.left }}%; --width: {{ month.width }}%; --height: {{ month.height }}px;" title="{{ month.count }} {{ "commit" if month.count == 1 else "commits" }} in {{ month.month }}"></span>
            {% endfor %}
            {% if item.created_left is not none %}<span class="timeline-marker created" style="--left: {{ item.created_left }}%;" title="Repository created: {{ github.created_at[:10] }}"></span>{% endif %}
            {% if item.pushed_left is not none %}<span class="timeline-marker pushed" style="--left: {{ item.pushed_left }}%;" title="Last push: {{ github.pushed_at[:10] }}"></span>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </article>

    {% if software_language_chart %}
    <article class="chart-card language-card">
      {{ common.section_heading("Codebase", "Languages", compact=true) }}
      <div class="language-stack" aria-label="Aggregated repository languages">
        {% for language in software_language_chart %}
        <span style="width: {{ language.share }}%; background: {{ language.color }};" title="{{ language.name }}: {{ language.share }}%"></span>
        {% endfor %}
      </div>
      <div class="language-list">
        {% for language in software_language_chart %}
        <div>
          <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
          <strong>{{ language.share }}%</strong>
        </div>
        {% endfor %}
      </div>
    </article>
    {% endif %}
  </div>
  {% endif %}
  <div class="software-layout">
    <aside class="software-snapshot" aria-label="Software portfolio metrics">
      <div class="section-heading compact">
        <p class="eyebrow">Snapshot</p>
        <h3>Software Index</h3>
      </div>
      <div class="snapshot-grid">
        <div><strong>{{ metrics.software_projects }}</strong><span>Repos</span></div>
        <div><strong>{{ metrics.software_packages }}</strong><span>Packages</span></div>
        {% if software_github.repositories_with_stats %}
        <div><strong>{{ software_github.total_stars }}</strong><span>Stars</span></div>
        <div><strong>{{ software_github.total_forks }}</strong><span>Forks</span></div>
        {% endif %}
      </div>
      {% if software_github.repositories_with_stats %}
      <div class="snapshot-detail">
        <span>Latest push</span>
        <strong>{{ software_github.last_push_date }}</strong>
      </div>
      {% endif %}
      {% if software_language_chart %}
      <div class="snapshot-detail">
        <span>Dominant language</span>
        <strong>{{ software_language_chart[0].name }}</strong>
      </div>
      <div class="snapshot-language-key">
        {% for language in software_language_chart[:5] %}
        <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </aside>
    <div class="repo-list">
      {% for project in software_projects %}
      {% set github = project.get("github") %}
      <article class="repo-row">
        <div class="repo-identity">
          <div class="software-meta">
            <span>{{ project.type }}</span>
          </div>
          <h3>{% if project.urls.github %}<a href="{{ project.urls.github }}">{{ project.name }}</a>{% else %}{{ project.name }}{% endif %}</h3>
          {% if project.full_name %}<p>{{ project.full_name }}</p>{% endif %}
        </div>
        <div class="repo-summary">
          {% if project.description %}<p>{{ project.description }}</p>{% endif %}
          <div class="repo-tags">
            {% for domain in project.domains %}
            <span>{{ domain }}</span>
            {% endfor %}
          </div>
        </div>
        {% if github %}
        <div class="repo-stats">
          <div class="repo-statline">
            {% if github.language %}<span>{{ github.language }}</span>{% endif %}
            {% if github.license %}<span>{{ github.license }}</span>{% endif %}
            <span>{{ github.stargazers_count }} stars</span>
            <span>{{ github.forks_count }} forks</span>
            <span>{{ github.open_issues_count }} open</span>
            {% if github.commits_count is not none %}<span>{{ github.commits_count }} commits</span>{% endif %}
          </div>
          {% if github.first_commit_at or github.last_commit_at or github.pushed_at %}
          <div class="repo-dates">
            {% if github.first_commit_at and github.last_commit_at %}
            <span>Commits {{ github.first_commit_at[:10] }} - {{ github.last_commit_at[:10] }}</span>
            {% endif %}
            {% if github.pushed_at %}
            <span>Push {{ github.pushed_at[:10] }}</span>
            {% endif %}
          </div>
          {% endif %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
  <h3 class="subsection-title">Software Packages</h3>
  <div class="package-grid">
    {% for package in software_packages %}
    {% set stats = package.get("package_stats", {}) %}
    <article class="package-card">
      <div class="software-meta"><span>{{ package.ecosystem }}</span>{% if package.get("package_name") %}<span>{{ package.package_name }}</span>{% endif %}{% if package.get("group_id") %}<span>{{ package.group_id }}:{{ package.artifact_id }}</span>{% endif %}</div>
      <h3><a href="{{ stats.get("package_url") or stats.get("mvnrepository_url") or package.get("url", "#") }}">{{ package.name }}</a></h3>
      {% if stats.get("summary") %}<p>{{ stats.summary }}</p>{% endif %}

      {% if package.ecosystem == "PyPI" and stats %}
      <div class="package-stat-grid">
        <div><strong>{{ stats.total_downloads | number }}</strong><span>Total downloads</span></div>
        <div><strong>{{ stats.latest_version }}</strong><span>Latest version</span></div>
        <div><strong>{{ stats.release_count }}</strong><span>Releases</span></div>
        <div><strong>{{ stats.requires_python or "n/a" }}</strong><span>Python</span></div>
      </div>
      {% if stats.download_chart %}
      {% set chart_points = stats.download_chart[-18:] %}
      {% set max_downloads = chart_points | map(attribute="downloads") | max %}
      <div class="package-download-chart" aria-label="{{ package.name }} monthly downloads by version">
        <div class="chart-y-axis">
          <span>{{ max_downloads | number }}</span>
          <span>{{ (max_downloads / 2) | round | int | number }}</span>
          <span>0</span>
        </div>
        <div class="chart-plot">
          <div class="chart-grid-line top"></div>
          <div class="chart-grid-line middle"></div>
          <div class="package-bars">
            {% for point in chart_points %}
            <div class="package-bar" style="height: {{ ((point.downloads / max_downloads) * 100) | round }}%" title="{{ point.label }} · {{ point.downloads | number }} downloads">
              {% for segment in point.segments %}
              <span style="height: {{ segment.share }}%; background: {{ segment.color }};" title="{{ point.label }} · {{ segment.version }} · {{ segment.downloads | number }} downloads"></span>
              {% endfor %}
            </div>
            {% endfor %}
          </div>
          <div class="chart-x-axis">
            {% for point in chart_points %}
            <span>{{ point.label.split(" ")[0] }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
      {% endif %}
      <div class="package-splits">
        <div>
          <h4>Versions</h4>
          <div class="package-scroll-list">
            {% for item in stats.downloads_by_version %}
            <p><span><i style="background: {{ item.color }};"></i>{{ item.version }}</span><strong>{{ item.downloads | number }}</strong></p>
            {% endfor %}
          </div>
        </div>
        <div>
          <h4>Countries</h4>
          <div class="package-scroll-list">
            {% for item in stats.downloads_by_country %}
            <p><span>{{ item.country_code }}</span><strong>{{ item.downloads | number }}</strong></p>
            {% endfor %}
          </div>
        </div>
      </div>
      <p class="tags"><a href="{{ stats.clickpy_url }}">ClickPy dashboard</a></p>
      {% elif package.ecosystem == "Maven" and stats %}
      <div class="package-stat-grid">
        <div><strong>{{ stats.latest_version }}</strong><span>Latest version</span></div>
        <div><strong>{{ stats.release_count }}</strong><span>Releases</span></div>
        <div><strong>{{ stats.dependency_count }}</strong><span>Dependencies</span></div>
        <div><strong>{{ stats.java_release or "n/a" }}</strong><span>Java release</span></div>
      </div>
      <ul class="meta-list">
        {% if stats.license %}<li>License: {{ stats.license }}</li>{% endif %}
        {% if stats.last_updated %}<li>Last updated: {{ stats.last_updated }}</li>{% endif %}
        {% if stats.project_url %}<li>Project: <a href="{{ stats.project_url }}">{{ stats.project_url }}</a></li>{% endif %}
      </ul>
      {% if stats.artifact_files %}
      <div class="artifact-list">
        {% for artifact in stats.artifact_files %}
        <a href="{{ artifact.url }}"><span>{{ artifact.kind }}</span><strong>{{ (artifact.size_bytes / 1024) | round | int }} KB</strong></a>
        {% endfor %}
      </div>
      {% endif %}
      <p class="tags"><a href="{{ stats.mvnrepository_url }}">MvnRepository</a></p>
      {% else %}
      <p class="tags">
        {% if package.get("package_name") %}Package: {{ package.package_name }}{% endif %}
        {% if package.get("group_id") %}Coordinate: {{ package.group_id }}:{{ package.artifact_id }}{% endif %}
      </p>
      {% endif %}
    </article>
    {% endfor %}
  </div>
</section>
