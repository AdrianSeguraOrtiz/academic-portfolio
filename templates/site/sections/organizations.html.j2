{% import "macros/common.html.j2" as common %}
{% macro organization_card(organization) %}
<article class="organization-card depth-{{ organization.depth }}">
  <div class="record-topline">
    <span>{{ organization.type }}</span>
    {% if organization.city %}<time>{{ organization.city }}</time>{% endif %}
  </div>
  <h3>{% if organization.website %}<a href="{{ organization.website }}">{{ organization.name }}</a>{% else %}{{ organization.name }}{% endif %}</h3>
  {% if organization.full_name != organization.name %}<p>{{ organization.full_name }}</p>{% endif %}
  <p class="organization-path">{{ organization.path_label }}</p>
  <div class="organization-card-metrics">
    {% for metric in organization.metrics %}
    <span class="rel-{{ metric.id }}">{{ metric.label }} · {{ metric.value_label }}</span>
    {% endfor %}
  </div>
  {% if organization.children %}
  <div class="organization-children">
    <p class="organization-children-label">Contained organizations</p>
    {% for child in organization.children %}
    {{ organization_card(child) }}
    {% endfor %}
  </div>
  {% endif %}
</article>
{% endmacro %}

<section class="content-section" id="organizations">
  {{ common.section_heading("Entities", "Organizations") }}
  <div class="organization-summary">
    <article>
      <strong>{{ organization_network.metrics.organizations }}</strong>
      <span>linked organizations</span>
    </article>
    <article>
      <strong>{{ organization_network.metrics.countries }}</strong>
      <span>countries</span>
    </article>
    <article>
      <strong>{{ organization_network.metrics.cities }}</strong>
      <span>cities</span>
    </article>
  </div>

  <div class="organization-directory" data-organization-tabs>
    <div class="organization-country-tabs" role="tablist" aria-label="Organization countries">
      {% for country in organization_network.cards %}
      <button
        type="button"
        class="{% if loop.first %}active{% endif %}"
        id="organization-tab-{{ loop.index0 }}"
        role="tab"
        aria-controls="organization-panel-{{ loop.index0 }}"
        aria-selected="{{ 'true' if loop.first else 'false' }}"
        data-organization-tab="{{ loop.index0 }}"
      >
        <span>{{ country.country }}</span>
        <small>{{ country.cities | length }} {{ "city" if country.cities | length == 1 else "cities" }}</small>
      </button>
      {% endfor %}
    </div>
    <div class="organization-country-panels">
    {% for country in organization_network.cards %}
    <section
      class="organization-country-panel{% if loop.first %} active{% endif %}"
      id="organization-panel-{{ loop.index0 }}"
      role="tabpanel"
      aria-labelledby="organization-tab-{{ loop.index0 }}"
      data-organization-panel="{{ loop.index0 }}"
      {% if not loop.first %}hidden{% endif %}
    >
      <div class="organization-country-heading">
        <h3>{{ country.country }}</h3>
      </div>
      {% for city in country.cities %}
      <div class="organization-city-group">
        <h4>{{ city.city }}</h4>
        <div class="organization-hierarchy-list">
          {% for organization in city.organizations %}
          {{ organization_card(organization) }}
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>
    {% endfor %}
    </div>
  </div>
</section>
