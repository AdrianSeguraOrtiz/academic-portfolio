<!doctype html>
<html lang="{{ language }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ profile.person.full_name }} | {{ t("site.document.title_suffix") }}</title>
    <meta name="description" content="{{ profile.research_profile.summary }}">
    <link rel="stylesheet" href="assets/site.css">
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="{{ t("site.aria.primary_navigation") }}">
        <a href="#profile">{{ t("nav.profile") }}</a>
        <a href="#overview">{{ t("nav.overview") }}</a>
        <a href="#collaborations">{{ t("nav.collaborations") }}</a>
        <a href="#publications">{{ t("nav.publications") }}</a>
        <a href="#software">{{ t("nav.software") }}</a>
        <a href="#career">{{ t("nav.career") }}</a>
        <a href="#research-projects">{{ t("nav.projects") }}</a>
        <a href="#teaching">{{ t("nav.teaching") }}</a>
        <a href="#dissemination">{{ t("nav.dissemination") }}</a>
        <a href="#organizations">{{ t("nav.organizations") }}</a>
        <div class="language-switcher" aria-label="{{ t("site.aria.language_switcher") }}">
          {% for option in language_switcher %}
          {% if option.is_current %}
          <span aria-label="{{ t("site.aria.current_language") }}">{{ option.label }}</span>
          {% else %}
          <a href="{{ option.url }}" hreflang="{{ option.code }}">{{ option.label }}</a>
          {% endif %}
          {% endfor %}
        </div>
      </nav>
    </header>

    <main>
      {% include "sections/profile.html.j2" %}
      {% include "sections/overview.html.j2" %}
      {% include "sections/collaborations.html.j2" %}
      {% include "sections/publications.html.j2" %}
      {% include "sections/software.html.j2" %}
      {% include "sections/career.html.j2" %}
      {% include "sections/projects.html.j2" %}
      {% include "sections/teaching.html.j2" %}
      {% include "sections/dissemination.html.j2" %}
      {% include "sections/organizations.html.j2" %}
    </main>
    <script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
    <script src="assets/ui.js"></script>
    <script src="assets/collaborations.js"></script>
    <script src="assets/publications.js"></script>
    <script src="assets/software-timeline.js"></script>
    <script src="assets/career-timeline.js"></script>
    <script src="assets/career-details.js"></script>
    <script src="assets/projects.js"></script>
    <script src="assets/teaching-timeline.js"></script>
    <script src="assets/dissemination.js"></script>
    <script src="assets/organizations.js"></script>
  </body>
</html>
