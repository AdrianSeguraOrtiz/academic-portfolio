<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ profile.person.full_name }} | Academic Portfolio</title>
    <meta name="description" content="{{ profile.research_profile.summary }}">
    <link rel="stylesheet" href="assets/site.css">
  </head>
  <body>
    {% macro org_links(record) -%}
      {%- for organization in record.get("resolved", {}).get("organization_ids", []) -%}
        <a href="{{ organization.website }}">{{ organization.name }}</a>{% if not loop.last %}, {% endif %}
      {%- endfor -%}
    {%- endmacro %}

    {% macro date_span(record) -%}
      {%- if record.get("start_date") or record.get("end_date") -%}
        {{ record.get("start_date") | date_range(record.get("end_date")) }}
      {%- endif -%}
    {%- endmacro %}

    {% macro linked_records(records) -%}
      {%- for record in records -%}
        {%- set url = record.get("url") or record.get("website") or record.get("urls", {}).get("github") -%}
        {%- if url -%}<a href="{{ url }}">{{ record | record_name }}</a>{%- else -%}{{ record | record_name }}{%- endif -%}{% if not loop.last %}, {% endif %}
      {%- endfor -%}
    {%- endmacro %}

    {% macro relationship_node(node, relationship_id) %}
    <article class="relationship-node depth-{{ node.depth }} rel-scope-{{ relationship_id }} {{ node.size_class }}" style="{{ node.style }}" title="{{ node.tooltip }}">
      <div class="relationship-node-label">
        {% if node.website %}<a href="{{ node.website }}">{{ node.label }}</a>{% else %}<span>{{ node.label }}</span>{% endif %}
        <small>{{ node.value_label }}</small>
      </div>
      <div class="relationship-node-bar" aria-hidden="true"></div>
      {% if node.children %}
      <div class="relationship-child-stack" style="{{ node.children_style }}">
        {% for child in node.children %}
        {{ relationship_node(child, relationship_id) }}
        {% endfor %}
      </div>
      {% endif %}
    </article>
    {% endmacro %}

    {% macro publication_card(publication) %}
    <article class="record-card">
      <div class="record-topline">
        <span class="kind-dot {{ publication.publication_kind }}"></span>
        <span>{{ "Journal paper" if publication.publication_kind == "journal" else "Conference paper" }}</span>
        {% if publication.publication_date %}<time>{{ publication.publication_date }}</time>{% endif %}
      </div>
      <h3><a href="{{ publication.url }}">{{ publication.title }}</a></h3>
      <p>{{ publication.authors | join(", ") }}</p>
      <p><strong>{{ publication.venue }}</strong>{% if publication.publisher %} · {{ publication.publisher }}{% endif %}</p>
      <ul class="meta-list">
        {% if publication.doi %}<li>DOI: <a href="{{ publication.url }}">{{ publication.doi }}</a></li>{% endif %}
        {% if publication.get("resolved", {}).get("organization_ids", []) %}<li>Organizations: {{ org_links(publication) }}</li>{% endif %}
        {% if publication.get("resolved", {}).get("position_ids", []) %}<li>Positions: {{ linked_records(publication.resolved.position_ids) }}</li>{% endif %}
        {% if publication.get("resolved", {}).get("stay_ids", []) %}<li>Research stays: {{ linked_records(publication.resolved.stay_ids) }}</li>{% endif %}
        {% if publication.get("resolved", {}).get("grant_ids", []) %}<li>Grants: {{ linked_records(publication.resolved.grant_ids) }}</li>{% endif %}
        {% if publication.get("resolved", {}).get("software_project_ids", []) %}
        <li>Software:
          {% for software in publication.resolved.software_project_ids %}
          <a href="{{ software.urls.github }}">{{ software.name }}</a>{% if not loop.last %}, {% endif %}
          {% endfor %}
        </li>
        {% endif %}
      </ul>
    </article>
    {% endmacro %}

    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a href="#profile">Profile</a>
        <a href="#overview">Overview</a>
        <a href="#collaborations">Collaborations</a>
        <a href="#publications">Publications</a>
        <a href="#software">Software</a>
        <a href="#career">Career</a>
        <a href="#research-projects">Projects</a>
        <a href="#teaching">Teaching</a>
        <a href="#dissemination">Dissemination</a>
        <a href="#organizations">Organizations</a>
      </nav>
    </header>

    <main>
      <section class="hero" id="profile">
        <div class="hero-copy">
          <p class="eyebrow">Academic Portfolio</p>
          <h1>{{ profile.person.full_name }}</h1>
          <p class="lead">{{ profile.research_profile.summary }}</p>

          <div class="current-activity" aria-label="Current activity">
            {% for position in profile.current_positions %}
            <article class="current-card">
              <span>Current position</span>
              <strong>{{ position.title }}</strong>
              <p>{{ org_links(position) }}{% if date_span(position) %} · {{ date_span(position) }}{% endif %}</p>
            </article>
            {% endfor %}
            {% for stay in profile.current_stays %}
            <article class="current-card">
              <span>Current stay</span>
              <strong>{{ stay.title }}</strong>
              <p>{{ org_links(stay) }}{% if date_span(stay) %} · {{ date_span(stay) }}{% endif %}</p>
            </article>
            {% endfor %}
          </div>

          <div class="profile-links" aria-label="Profile links">
            {% if profile.person.identifiers.orcid %}
            <a href="https://orcid.org/{{ profile.person.identifiers.orcid }}">ORCID</a>
            {% endif %}
            {% if profile.links.linkedin %}
            <a href="{{ profile.links.linkedin }}">LinkedIn</a>
            {% endif %}
            {% if profile.links.github %}
            <a href="{{ profile.links.github }}">GitHub</a>
            {% endif %}
            {% if profile.links.docker_hub %}
            <a href="{{ profile.links.docker_hub }}">Docker Hub</a>
            {% endif %}
            <a href="mailto:{{ profile.contact.email }}">{{ profile.contact.email }}</a>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Research focus">
          <h2>Research Focus</h2>
          <div class="focus-list">
            {% for area in research_focus %}
            <span>{{ area }}</span>
            {% endfor %}
          </div>
        </aside>
      </section>

      <section class="section overview" id="overview">
        <div class="overview-copy">
          <div class="section-heading">
            <p class="eyebrow">At a Glance</p>
            <h2>Research, Software, Teaching, and Dissemination</h2>
          </div>

          <div class="narrative">
            <p>
              My research activity is focused on artificial intelligence and bioinformatics,
              with particular attention to gene regulatory network inference, evolutionary
              biclustering, biomedical data analysis, and the integration of domain knowledge
              into computational methods. This work has resulted in
              <strong>{{ metrics.journal_papers }} journal papers</strong> and
              <strong>{{ metrics.conference_papers }} conference paper</strong>, supported by
              open research software and reproducible computational assets.
            </p>
            <p>
              The technological output of this portfolio includes
              <strong>{{ metrics.software_projects }} software projects</strong> and
              <strong>{{ metrics.software_packages }} software packages</strong>. Scientific
              dissemination includes <strong>{{ metrics.scientific_dissemination_articles }}
              scientific dissemination articles</strong>, <strong>{{ metrics.presentations }}
              presentations</strong>, <strong>{{ metrics.press_items }} press items</strong>,
              <strong>{{ metrics.social_media_items }} social media items</strong>, and
              <strong>{{ metrics.tv_media_items }} TV media item</strong>.
            </p>
            <p>
              Teaching activity includes <strong>{{ metrics.courses }} university courses</strong>
              and <strong>{{ metrics.supervisions }} academic supervision activities</strong>.
              The academic trajectory includes <strong>{{ metrics.honors }} honors</strong>,
              <strong>{{ metrics.grants }} grants</strong>, and
              <strong>{{ metrics.research_stays }} international research stays</strong>.
            </p>
          </div>
        </div>

        <aside class="metric-grid" aria-label="Portfolio metrics">
          <article class="metric-card"><strong>{{ metrics.journal_papers }}</strong><span>Journal papers</span></article>
          <article class="metric-card"><strong>{{ metrics.conference_papers }}</strong><span>Conference papers</span></article>
          <article class="metric-card"><strong>{{ metrics.software_projects }}</strong><span>Software projects</span></article>
          <article class="metric-card"><strong>{{ metrics.software_packages }}</strong><span>Software packages</span></article>
          <article class="metric-card"><strong>{{ metrics.courses }}</strong><span>Courses taught</span></article>
          <article class="metric-card"><strong>{{ metrics.projects }}</strong><span>Projects</span></article>
          <article class="metric-card"><strong>{{ metrics.press_items }}</strong><span>Press items</span></article>
          <article class="metric-card"><strong>{{ metrics.social_media_items }}</strong><span>Social media items</span></article>
        </aside>
      </section>

      <section class="content-section" id="collaborations">
        <div class="section-heading">
          <p class="eyebrow">Collaborations</p>
          <h2>Research Stays and Publication Cities</h2>
        </div>
        <div class="collaboration-layout">
          <article class="collaboration-map-card">
            <div class="collaboration-map" data-collaboration-map role="img" aria-label="World map of research stays and publication collaborations">
              <span class="map-loading">Loading world map</span>
            </div>
            <div class="map-legend" aria-label="Map legend">
              <span><i class="legend-publication"></i> Publication city</span>
              <span><i class="legend-stay"></i> Research stay</span>
            </div>
            <script type="application/json" id="collaboration-map-data">{{ collaborations.map_data | tojson }}</script>
          </article>

          <aside class="collaboration-panel">
            <div class="collaboration-metric-block">
              <h3>Publications</h3>
              <div class="collaboration-metrics">
                <div><strong>{{ collaborations.metrics.total_papers }}</strong><span>Total papers</span></div>
                <div><strong>{{ collaborations.metrics.international_papers }}</strong><span>International papers</span></div>
                <div><strong>{{ collaborations.metrics.publication_countries }}</strong><span>Countries in papers</span></div>
              </div>
            </div>
            <div class="collaboration-metric-block">
              <h3>Research Stays</h3>
              <div class="collaboration-metrics">
                <div><strong>{{ collaborations.metrics.stay_cities }}</strong><span>Cities</span></div>
                <div><strong>{{ collaborations.metrics.stay_countries }}</strong><span>Countries</span></div>
                <div><strong>{{ collaborations.metrics.research_stays }}</strong><span>Stays</span></div>
                <div><strong>{{ collaborations.metrics.stay_months }}</strong><span>Months abroad</span></div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="content-section" id="publications">
        <div class="section-heading">
          <p class="eyebrow">Research Output</p>
          <h2>Publications</h2>
        </div>
        <div class="chart-card publication-chart-card">
          <div class="section-heading compact">
            <p class="eyebrow">Output</p>
            <h2>Publications by Year</h2>
          </div>
          <div class="chart-legend">
            <span><i class="kind-dot journal"></i> Journal paper</span>
            <span><i class="kind-dot conference"></i> Conference paper</span>
          </div>
          <div class="bar-chart" aria-label="Publications by year">
            {% for item in publication_chart %}
            <div class="bar-item">
              <div class="bar-track">
                <div class="bar-stack" style="height: {{ item.height }}%">
                  <span class="bar-segment journal" style="height: {{ item.journal_share }}%"></span>
                  <span class="bar-segment conference" style="height: {{ item.conference_share }}%"></span>
                </div>
              </div>
              <strong>{{ item.total }}</strong>
              <span>{{ item.year }}</span>
            </div>
            {% endfor %}
          </div>
        </div>
        <div class="record-grid">
          {% for publication in publications %}
          {{ publication_card(publication) }}
          {% endfor %}
        </div>
      </section>

      <section class="content-section" id="software">
        <div class="section-heading">
          <p class="eyebrow">Open Research Software</p>
          <h2>Software</h2>
        </div>
        <h3 class="subsection-title">Software Projects</h3>
        {% if software_timeline.rows %}
        <div class="software-visual-grid">
          <article class="chart-card software-timeline-card">
            <div class="section-heading compact">
              <p class="eyebrow">Repositories</p>
              <h2>Commit Activity</h2>
            </div>
            <div class="timeline-years" style="grid-template-columns: repeat({{ software_timeline.years | length }}, minmax(0, 1fr))">
              {% for year in software_timeline.years %}
              <span>{{ year }}</span>
              {% endfor %}
            </div>
            <div class="timeline-rows">
              {% for item in software_timeline.rows %}
              {% set github = item.project.get("github") %}
              <div class="timeline-row" style="--language-color: {{ item.color }};">
                <a class="timeline-label" href="{{ item.project.urls.github }}">{{ item.project.name }}</a>
                <div class="timeline-track">
                  {% for month in item.months %}
                  <span class="activity-pulse" style="--left: {{ month.left }}%; --width: {{ month.width }}%; --height: {{ month.height }}px;" title="{{ month.count }} {{ "commit" if month.count == 1 else "commits" }} in {{ month.month }}"></span>
                  {% endfor %}
                  {% if item.created_left is not none %}<span class="timeline-marker created" style="--left: {{ item.created_left }}%;" title="Repository created: {{ github.created_at[:10] }}"></span>{% endif %}
                  {% if item.pushed_left is not none %}<span class="timeline-marker pushed" style="--left: {{ item.pushed_left }}%;" title="Last push: {{ github.pushed_at[:10] }}"></span>{% endif %}
                </div>
              </div>
              {% endfor %}
            </div>
          </article>

          {% if software_language_chart %}
          <article class="chart-card language-card">
            <div class="section-heading compact">
              <p class="eyebrow">Codebase</p>
              <h2>Languages</h2>
            </div>
            <div class="language-stack" aria-label="Aggregated repository languages">
              {% for language in software_language_chart %}
              <span style="width: {{ language.share }}%; background: {{ language.color }};" title="{{ language.name }}: {{ language.share }}%"></span>
              {% endfor %}
            </div>
            <div class="language-list">
              {% for language in software_language_chart %}
              <div>
                <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
                <strong>{{ language.share }}%</strong>
              </div>
              {% endfor %}
            </div>
          </article>
          {% endif %}
        </div>
        {% endif %}
        <div class="software-layout">
          <aside class="software-snapshot" aria-label="Software portfolio metrics">
            <div class="section-heading compact">
              <p class="eyebrow">Snapshot</p>
              <h3>Software Index</h3>
            </div>
            <div class="snapshot-grid">
              <div><strong>{{ metrics.software_projects }}</strong><span>Repos</span></div>
              <div><strong>{{ metrics.software_packages }}</strong><span>Packages</span></div>
              {% if software_github.repositories_with_stats %}
              <div><strong>{{ software_github.total_stars }}</strong><span>Stars</span></div>
              <div><strong>{{ software_github.total_forks }}</strong><span>Forks</span></div>
              {% endif %}
            </div>
            {% if software_github.repositories_with_stats %}
            <div class="snapshot-detail">
              <span>Latest push</span>
              <strong>{{ software_github.last_push_date }}</strong>
            </div>
            {% endif %}
            {% if software_language_chart %}
            <div class="snapshot-detail">
              <span>Dominant language</span>
              <strong>{{ software_language_chart[0].name }}</strong>
            </div>
            <div class="snapshot-language-key">
              {% for language in software_language_chart[:5] %}
              <span><i style="background: {{ language.color }};"></i>{{ language.name }}</span>
              {% endfor %}
            </div>
            {% endif %}
          </aside>
          <div class="repo-list">
            {% for project in software_projects %}
            {% set github = project.get("github") %}
            <article class="repo-row">
              <div class="repo-identity">
                <div class="software-meta">
                  <span>{{ project.type }}</span>
                </div>
                <h3>{% if project.urls.github %}<a href="{{ project.urls.github }}">{{ project.name }}</a>{% else %}{{ project.name }}{% endif %}</h3>
                {% if project.full_name %}<p>{{ project.full_name }}</p>{% endif %}
              </div>
              <div class="repo-summary">
                {% if project.description %}<p>{{ project.description }}</p>{% endif %}
                <div class="repo-tags">
                  {% for domain in project.domains %}
                  <span>{{ domain }}</span>
                  {% endfor %}
                </div>
              </div>
              {% if github %}
              <div class="repo-stats">
                <div class="repo-statline">
                  {% if github.language %}<span>{{ github.language }}</span>{% endif %}
                  {% if github.license %}<span>{{ github.license }}</span>{% endif %}
                  <span>{{ github.stargazers_count }} stars</span>
                  <span>{{ github.forks_count }} forks</span>
                  <span>{{ github.open_issues_count }} open</span>
                  {% if github.commits_count is not none %}<span>{{ github.commits_count }} commits</span>{% endif %}
                </div>
                {% if github.first_commit_at or github.last_commit_at or github.pushed_at %}
                <div class="repo-dates">
                  {% if github.first_commit_at and github.last_commit_at %}
                  <span>Commits {{ github.first_commit_at[:10] }} - {{ github.last_commit_at[:10] }}</span>
                  {% endif %}
                  {% if github.pushed_at %}
                  <span>Push {{ github.pushed_at[:10] }}</span>
                  {% endif %}
                </div>
                {% endif %}
              </div>
              {% endif %}
            </article>
            {% endfor %}
          </div>
        </div>
        <h3 class="subsection-title">Software Packages</h3>
        <div class="package-grid">
          {% for package in software_packages %}
          {% set stats = package.get("package_stats", {}) %}
          <article class="package-card">
            <div class="software-meta"><span>{{ package.ecosystem }}</span>{% if package.get("package_name") %}<span>{{ package.package_name }}</span>{% endif %}{% if package.get("group_id") %}<span>{{ package.group_id }}:{{ package.artifact_id }}</span>{% endif %}</div>
            <h3><a href="{{ stats.get("package_url") or stats.get("mvnrepository_url") or package.get("url", "#") }}">{{ package.name }}</a></h3>
            {% if stats.get("summary") %}<p>{{ stats.summary }}</p>{% endif %}

            {% if package.ecosystem == "PyPI" and stats %}
            <div class="package-stat-grid">
              <div><strong>{{ stats.total_downloads | number }}</strong><span>Total downloads</span></div>
              <div><strong>{{ stats.latest_version }}</strong><span>Latest version</span></div>
              <div><strong>{{ stats.release_count }}</strong><span>Releases</span></div>
              <div><strong>{{ stats.requires_python or "n/a" }}</strong><span>Python</span></div>
            </div>
            {% if stats.download_chart %}
            {% set chart_points = stats.download_chart[-18:] %}
            {% set max_downloads = chart_points | map(attribute="downloads") | max %}
            <div class="package-download-chart" aria-label="{{ package.name }} monthly downloads by version">
              <div class="chart-y-axis">
                <span>{{ max_downloads | number }}</span>
                <span>{{ (max_downloads / 2) | round | int | number }}</span>
                <span>0</span>
              </div>
              <div class="chart-plot">
                <div class="chart-grid-line top"></div>
                <div class="chart-grid-line middle"></div>
                <div class="package-bars">
                  {% for point in chart_points %}
                  <div class="package-bar" style="height: {{ ((point.downloads / max_downloads) * 100) | round }}%" title="{{ point.label }} · {{ point.downloads | number }} downloads">
                    {% for segment in point.segments %}
                    <span style="height: {{ segment.share }}%; background: {{ segment.color }};" title="{{ point.label }} · {{ segment.version }} · {{ segment.downloads | number }} downloads"></span>
                    {% endfor %}
                  </div>
                  {% endfor %}
                </div>
                <div class="chart-x-axis">
                  {% for point in chart_points %}
                  <span>{{ point.label.split(" ")[0] }}</span>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% endif %}
            <div class="package-splits">
              <div>
                <h4>Versions</h4>
                <div class="package-scroll-list">
                  {% for item in stats.downloads_by_version %}
                  <p><span><i style="background: {{ item.color }};"></i>{{ item.version }}</span><strong>{{ item.downloads | number }}</strong></p>
                  {% endfor %}
                </div>
              </div>
              <div>
                <h4>Countries</h4>
                <div class="package-scroll-list">
                  {% for item in stats.downloads_by_country %}
                  <p><span>{{ item.country_code }}</span><strong>{{ item.downloads | number }}</strong></p>
                  {% endfor %}
                </div>
              </div>
            </div>
            <p class="tags"><a href="{{ stats.clickpy_url }}">ClickPy dashboard</a></p>
            {% elif package.ecosystem == "Maven" and stats %}
            <div class="package-stat-grid">
              <div><strong>{{ stats.latest_version }}</strong><span>Latest version</span></div>
              <div><strong>{{ stats.release_count }}</strong><span>Releases</span></div>
              <div><strong>{{ stats.dependency_count }}</strong><span>Dependencies</span></div>
              <div><strong>{{ stats.java_release or "n/a" }}</strong><span>Java release</span></div>
            </div>
            <ul class="meta-list">
              {% if stats.license %}<li>License: {{ stats.license }}</li>{% endif %}
              {% if stats.last_updated %}<li>Last updated: {{ stats.last_updated }}</li>{% endif %}
              {% if stats.project_url %}<li>Project: <a href="{{ stats.project_url }}">{{ stats.project_url }}</a></li>{% endif %}
            </ul>
            {% if stats.artifact_files %}
            <div class="artifact-list">
              {% for artifact in stats.artifact_files %}
              <a href="{{ artifact.url }}"><span>{{ artifact.kind }}</span><strong>{{ (artifact.size_bytes / 1024) | round | int }} KB</strong></a>
              {% endfor %}
            </div>
            {% endif %}
            <p class="tags"><a href="{{ stats.mvnrepository_url }}">MvnRepository</a></p>
            {% else %}
            <p class="tags">
              {% if package.get("package_name") %}Package: {{ package.package_name }}{% endif %}
              {% if package.get("group_id") %}Coordinate: {{ package.group_id }}:{{ package.artifact_id }}{% endif %}
            </p>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </section>

      <section class="content-section" id="career">
        <div class="section-heading">
          <p class="eyebrow">Career</p>
          <h2>Education, Experience, Stays, Honors, and Grants</h2>
        </div>
        <div class="career-timeline-card">
          <div class="career-timeline-toolbar" aria-label="Career timeline filters">
            {% for filter in career_timeline.filters %}
            <button type="button" class="career-filter active" data-career-filter="{{ filter.id }}" aria-pressed="true">{{ filter.label }}</button>
            {% endfor %}
            <button type="button" class="career-reset" data-career-reset>Reset zoom</button>
          </div>
          <div class="career-timeline-scroll">
            <div class="career-timeline" data-career-timeline role="img" aria-label="Career timeline visualization">
              <span class="map-loading">Loading career timeline</span>
            </div>
          </div>
          <div class="career-timeline-legend" aria-label="Career timeline legend">
            <span><i class="legend-education"></i> Education</span>
            <span><i class="legend-experience"></i> Experience</span>
            <span><i class="legend-stay-block"></i> Research stay</span>
            <span><i class="legend-certification"></i> Certification</span>
            <span><i class="legend-honor"></i> Honor</span>
            <span><i class="legend-grant"></i> Grant-linked block</span>
          </div>
          <script type="application/json" id="career-timeline-data">{{ career_timeline | tojson }}</script>
        </div>
        <div class="career-detail-tabs" aria-label="Career detail categories">
          <a href="#career-education"><span>{{ career.degrees | length }}</span> Education</a>
          <a href="#career-experience"><span>{{ career.experience | length }}</span> Experience</a>
          <a href="#career-stays"><span>{{ career.research_stays | length }}</span> Stays</a>
          <a href="#career-certifications"><span>{{ career.certifications | length }}</span> Certifications</a>
          <a href="#career-honors"><span>{{ career.honors | length }}</span> Honors</a>
          <a href="#career-grants"><span>{{ career.grants | length }}</span> Grants</a>
        </div>
        <div class="career-detail-sections">
          <section id="career-education" class="career-detail-section education">
            <div class="career-detail-heading">
              <p class="eyebrow">Education</p>
              <h3>Degrees</h3>
            </div>
            <div class="career-card-grid">
            {% for degree in career.degrees %}
            <article class="career-card education">
              <div class="record-topline"><span>{{ degree.level }}</span><time>{{ degree.start_date | date_range(degree.end_date) }}</time></div>
              <h3>{{ degree.title }}</h3>
              <p>{{ org_links(degree) }} · {{ degree.start_date | date_range(degree.end_date) }}</p>
              {% if degree.grade %}<p>{{ degree.grade }}</p>{% endif %}
              {% if degree.get("resolved", {}).get("grant_ids", []) %}<p>Grants: {{ linked_records(degree.resolved.grant_ids) }}</p>{% endif %}
              {% if degree.thesis.title %}<p>{{ degree.thesis.type }}: {{ degree.thesis.title }}</p>{% endif %}
              {% if degree.thesis.area %}<p class="tags">{{ degree.thesis.area }}</p>{% endif %}
            </article>
            {% endfor %}
            </div>
          </section>
          <section id="career-experience" class="career-detail-section experience">
            <div class="career-detail-heading">
              <p class="eyebrow">Experience</p>
              <h3>Positions</h3>
            </div>
            <div class="career-card-grid experience-grid">
            {% for position in career.experience %}
            <article class="career-card experience">
              <div class="record-topline"><span>{{ position.employment_type or position.dedication or "Position" }}</span><time>{{ date_span(position) }}</time></div>
              <h3>{{ position.title }}</h3>
              <p>{{ org_links(position) }} · {{ date_span(position) }}</p>
              <ul class="meta-list">
                {% if position.location %}<li>Location: {{ position.location }}</li>{% endif %}
                {% if position.employment_type or position.dedication or position.work_mode %}<li>Type: {{ [position.employment_type, position.dedication, position.work_mode] | select | unique | join(", ") }}</li>{% endif %}
                {% if position.department %}<li>Department: {{ position.department }}</li>{% endif %}
                {% if position.group %}<li>Group: {{ position.group }}</li>{% endif %}
              </ul>
              {% if position.tasks %}
              <details class="task-details">
                <summary>Tasks ({{ position.tasks | length }})</summary>
                <ul class="meta-list">
                  {% for task in position.tasks %}
                  <li>{{ task }}</li>
                  {% endfor %}
                </ul>
              </details>
              {% endif %}
            </article>
            {% endfor %}
            </div>
          </section>
          <section id="career-stays" class="career-detail-section stay">
            <div class="career-detail-heading">
              <p class="eyebrow">Research Stays</p>
              <h3>International Mobility</h3>
            </div>
            <div class="career-card-grid">
            {% for stay in career.research_stays %}
            <article class="career-card stay">
              <div class="record-topline"><span>{{ stay.type or "Research stay" }}</span><time>{{ date_span(stay) }}</time></div>
              <h3>{{ stay.title }}</h3>
              <p>{{ org_links(stay) }} · {{ date_span(stay) }}</p>
              <p>{{ stay.description }}</p>
              <ul class="meta-list">
                {% if stay.location.city %}<li>Location: {{ stay.location.city }}, {{ stay.location.country }}</li>{% endif %}
                {% if stay.host_group %}<li>Host group: {{ stay.host_group }}</li>{% endif %}
                {% if stay.purpose or stay.type %}<li>Purpose: {{ [stay.purpose, stay.type] | select | join(", ") }}</li>{% endif %}
                {% if stay.get("resolved", {}).get("grant_ids", []) %}<li>Grants: {{ linked_records(stay.resolved.grant_ids) }}</li>{% endif %}
                {% for task in stay.tasks %}<li>{{ task }}</li>{% endfor %}
              </ul>
            </article>
            {% endfor %}
            </div>
          </section>
          <section id="career-certifications" class="career-detail-section certification">
            <div class="career-detail-heading">
              <p class="eyebrow">Certifications</p>
              <h3>Credentials</h3>
            </div>
            <div class="career-card-grid compact-career-grid">
            {% for certification in career.certifications %}
            <article class="career-card certification">
              <div class="record-topline"><span>Certification</span>{% if certification.issue_date %}<time>{{ certification.issue_date }}</time>{% endif %}</div>
              <h3>{{ certification.title }}</h3>
              <p>{{ org_links(certification) }}{% if certification.issue_date %} · {{ certification.issue_date }}{% endif %}</p>
              <ul class="meta-list">
                {% if certification.duration_hours %}<li>{{ certification.duration_hours }} hours</li>{% endif %}
                {% if certification.credential_id %}<li>Credential ID: {{ certification.credential_id }}</li>{% endif %}
                {% if certification.notes %}<li>{{ certification.notes }}</li>{% endif %}
              </ul>
            </article>
            {% endfor %}
            </div>
          </section>
          <section id="career-honors" class="career-detail-section honor">
            <div class="career-detail-heading">
              <p class="eyebrow">Honors</p>
              <h3>Awards</h3>
            </div>
            <div class="career-card-grid compact-career-grid">
            {% for honor in career.honors %}
            <article class="career-card honor">
              <div class="record-topline"><span>Honor</span><time>{{ honor.issue_date }}</time></div>
              <h3>{{ honor.title }}</h3>
              <p>{{ honor.issue_date }} · {{ honor.awarding_entities | join(", ") }}</p>
              <p>{{ honor.context }}</p>
            </article>
            {% endfor %}
            </div>
          </section>
          <section id="career-grants" class="career-detail-section grant">
            <div class="career-detail-heading">
              <p class="eyebrow">Grants</p>
              <h3>Funding</h3>
            </div>
            <div class="career-card-grid compact-career-grid">
            {% for grant in career.grants %}
            <article class="career-card grant">
              <div class="record-topline"><span>{{ grant.awarding_entity_type }}</span><time>{{ grant.issue_date }}</time></div>
              <h3>{{ grant.name }}</h3>
              <p>{{ grant.issue_date }} · {{ grant.awarding_entity }}</p>
              <p>{{ grant.purpose }}</p>
              {% if date_span(grant) %}<p class="tags">{{ date_span(grant) }}</p>{% endif %}
              {% if grant.notes %}<p>{{ grant.notes }}</p>{% endif %}
            </article>
            {% endfor %}
            </div>
          </section>
        </div>
      </section>

      <section class="content-section" id="research-projects">
        <div class="section-heading">
          <p class="eyebrow">Projects</p>
          <h2>Research and Teaching Innovation Projects</h2>
        </div>
        <div class="project-role-legend" aria-label="Project role legend">
          <span><i class="role-working"></i> Working team member</span>
          <span><i class="role-research"></i> Research team member</span>
          <span><i class="role-lead"></i> PI / Co-PI</span>
        </div>
        <div class="project-grid">
          {% for project in projects %}
          <article class="project-card type-{{ project.project_type }} role-{{ project.participation_class }}">
            <div class="record-topline project-topline">
              <span class="project-type-label">{{ project.project_type_label }}</span>
              {% if project.get("code") %}<span>{{ project.code }}</span>{% endif %}
              {% if date_span(project) %}<time>{{ date_span(project) }}</time>{% endif %}
            </div>
            <h3>{{ project.display_title }}</h3>
            <p>{{ org_links(project) }}</p>
            {% if project.get("principal_investigators") %}<p>Principal investigators: {{ project.principal_investigators | join(", ") }}</p>{% endif %}
            <ul class="meta-list">
              {% if project.project_funders %}<li>Funders: {{ project.project_funders | join(", ") }}</li>{% endif %}
              {% if project.get("participation") %}<li>Participation: {{ project.participation }}</li>{% endif %}
              {% if project.get("total_amount_eur") %}<li>Total amount: {{ project.total_amount_eur }} EUR</li>{% endif %}
            </ul>
          </article>
          {% endfor %}
        </div>
      </section>

      <section class="content-section" id="teaching">
        <div class="section-heading">
          <p class="eyebrow">Teaching</p>
          <h2>Classes and Supervision</h2>
        </div>
        <div class="teaching-layout">
          <article class="teaching-timeline-card">
            <div class="teaching-timeline-legends">
              <div class="teaching-organization-legend" aria-label="Teaching institution color legend">
                {% for organization in teaching_timeline.legend %}
                <span><i style="--org-color: {{ organization.color }}"></i>{{ organization.label }}</span>
                {% endfor %}
              </div>
              <div class="teaching-type-legend" aria-label="Teaching item type legend">
                <span><i class="type-class"></i> Class</span>
                <span><i class="type-supervision"></i> Supervision</span>
              </div>
            </div>
            <div class="teaching-timeline-scroll">
              <div class="teaching-timeline-stage" style="{{ teaching_timeline.axis_style }}">
                <div class="teaching-axis"></div>
                {% for tick in teaching_timeline.year_ticks %}
                <span class="teaching-year-tick" style="--tick-top: {{ tick.top }}px">{{ tick.year }}</span>
                {% endfor %}
                {% for event in teaching_timeline.events %}
                <span class="teaching-timeline-connector side-{{ event.side }}" style="{{ event.connector_style }}"></span>
                <article class="teaching-timeline-item type-{{ event.type }} side-{{ event.side }}" style="{{ event.style }}">
                  <div class="teaching-event-kind">{{ event.type_label }}</div>
                  <h3>{% if event.url %}<a href="{{ event.url }}">{{ event.title }}</a>{% else %}{{ event.title }}{% endif %}</h3>
                  <p>{{ event.subtitle }}</p>
                  {% for detail in event.detail_lines %}<p>{{ detail }}</p>{% endfor %}
                  {% if event.repository_url %}<p><a href="{{ event.repository_url }}">Repository</a></p>{% endif %}
                  <time>{{ event.date_label }}</time>
                </article>
                {% endfor %}
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class="content-section" id="dissemination">
        <div class="section-heading">
          <p class="eyebrow">Knowledge Transfer</p>
          <h2>Dissemination and Media</h2>
        </div>
        <div class="dissemination-summary">
          <article class="dissemination-total">
            <strong>{{ dissemination_hub.total }}</strong>
            <span>Total dissemination items</span>
          </article>
          <div class="channel-mix" aria-label="Dissemination channel mix">
            {% for category in dissemination_hub.categories %}
            <div class="channel-row category-{{ category.id }}">
              <span>{{ category.label }}</span>
              <div class="channel-track"><i style="width: {{ category.share }}%"></i></div>
              <strong>{{ category.count }}</strong>
            </div>
            {% endfor %}
          </div>
        </div>

        <div class="dissemination-filters" data-dissemination-filters aria-label="Dissemination filters">
          <button type="button" class="active" data-filter="all" aria-pressed="true">All</button>
          {% for category in dissemination_hub.categories %}
          <button type="button" class="category-{{ category.id }}" data-filter="{{ category.id }}" aria-pressed="false">{{ category.label }}</button>
          {% endfor %}
        </div>

        <div class="dissemination-layout">
          <aside class="publication-impact">
            <h3>By Research Output</h3>
            <div class="publication-impact-list">
              {% for group in dissemination_hub.publication_groups %}
              <article>
                <strong>{% if group.publication.url %}<a href="{{ group.publication.url }}">{{ group.publication | record_name }}</a>{% else %}{{ group.publication | record_name }}{% endif %}</strong>
                <div class="impact-badges">
                  {% for badge in group.badges %}
                  <span class="category-{{ badge.category }}">{{ badge.count }} {{ badge.label }}</span>
                  {% endfor %}
                </div>
              </article>
              {% endfor %}
            </div>
          </aside>

          <div class="media-grid" data-dissemination-items>
            {% for item in dissemination_hub["items"] %}
            <article class="media-card category-{{ item.category }}" data-category="{{ item.category }}">
              <div class="record-topline">
                <span>{{ item.type_label }}</span>
                {% if item.date_label %}<time>{{ item.date_label }}</time>{% endif %}
              </div>
              <h3>{% if item.url %}<a href="{{ item.url }}">{{ item.display_title }}</a>{% else %}{{ item.display_title }}{% endif %}</h3>
              {% if item.source %}<p class="media-source">{{ item.source }}</p>{% endif %}
              {% for line in item.detail_lines %}<p>{{ line }}</p>{% endfor %}
              {% if item.description and item.description != item.display_title %}<p>{{ item.description }}</p>{% endif %}
              {% if item.get("resolved", {}).get("publication_ids", []) %}<p class="tags">Publications: {{ linked_records(item.resolved.publication_ids) }}</p>{% endif %}
              {% if item.get("resolved", {}).get("software_package_ids", []) %}<p class="tags">Software packages: {{ linked_records(item.resolved.software_package_ids) }}</p>{% endif %}
            </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <section class="content-section" id="organizations">
        <div class="section-heading">
          <p class="eyebrow">Entities</p>
          <h2>Organizations</h2>
        </div>
        <div class="organization-summary">
          <article>
            <strong>{{ organization_network.metrics.organizations }}</strong>
            <span>linked organizations</span>
          </article>
          <article>
            <strong>{{ organization_network.metrics.countries }}</strong>
            <span>countries</span>
          </article>
          <article>
            <strong>{{ organization_network.metrics.cities }}</strong>
            <span>cities</span>
          </article>
        </div>

        <div class="organization-legend" aria-label="Organization relationship type legend">
          {% for relationship in organization_network.relationship_types %}
          <span><i class="rel-{{ relationship.id }}"></i>{{ relationship.label }}</span>
          {% endfor %}
        </div>

        <div class="organization-relationship-chart" aria-label="Institutional relationships by type">
          {% for row in organization_network.rows %}
          <article class="organization-relationship-row rel-scope-{{ row.id }}">
            <div class="organization-relationship-heading">
              <div>
                <h3>{{ row.label }}</h3>
                <p>{{ row.total_label }}</p>
              </div>
              <span>{{ row.unit }}</span>
            </div>
            <div class="relationship-country-track" style="{{ row.track_style }}">
              {% for country in row.countries %}
              <section class="relationship-country-slice {{ country.size_class }}" style="{{ country.style }}" title="{{ country.country }} · {{ country.value_label }}">
                <div class="relationship-country-label">
                  <strong>{{ country.country }}</strong>
                  <span>{{ country.value_label }}</span>
                </div>
                <div class="relationship-country-bar" aria-hidden="true"></div>
                <div class="relationship-root-stack" style="{{ country.children_style }}">
                  {% for node in country.nodes %}
                  {{ relationship_node(node, row.id) }}
                  {% endfor %}
                </div>
              </section>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
        </div>

        <p class="organization-note">
          Each row uses its own unit. Publications are split across the most specific organizations involved in each paper and then propagated through the institutional hierarchy. Certificates-only organizations are omitted.
        </p>

        <div class="organization-directory">
          {% for country in organization_network.cards %}
          <section>
            <h3>{{ country.country }}</h3>
            {% for city in country.cities %}
            <div class="organization-city-group">
              <h4>{{ city.city }}</h4>
              <div class="organization-card-grid">
                {% for organization in city.organizations %}
                <article class="organization-card depth-{{ organization.depth }}">
                  <div class="record-topline">
                    <span>{{ organization.type }}</span>
                    {% if organization.city %}<time>{{ organization.city }}</time>{% endif %}
                  </div>
                  <h3>{% if organization.website %}<a href="{{ organization.website }}">{{ organization.name }}</a>{% else %}{{ organization.name }}{% endif %}</h3>
                  {% if organization.full_name != organization.name %}<p>{{ organization.full_name }}</p>{% endif %}
                  <p class="tags">{{ organization.path_label }}</p>
                  <div class="organization-card-metrics">
                    {% for metric in organization.metrics %}
                    <span class="rel-{{ metric.id }}">{{ metric.label }} · {{ metric.value_label }}</span>
                    {% endfor %}
                  </div>
                </article>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </section>
          {% endfor %}
        </div>
      </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
    <script src="assets/collaborations.js"></script>
    <script src="assets/career-timeline.js"></script>
    <script src="assets/dissemination.js"></script>
  </body>
</html>
